{
  "name": "node-red-contrib-surepetcare",
  "version": "0.2.0",
  "description": "Node-RED nodes for SurePetcare/SureFlap Connect smart cat flaps",
  "keywords": [
    "node-red",
    "sureflap",
    "surepetcare",
    "cat-flap",
    "pet"
  ],
  "author": "Dirk-Jan Faber",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dirkjanfaber/node-red-contrib-surepetcare.git"
  },
  "homepage": "https://github.com/dirkjanfaber/node-red-contrib-surepetcare#readme",
  "bugs": {
    "url": "https://github.com/dirkjanfaber/node-red-contrib-surepetcare/issues"
  },
  "files": [
    "dist/",
    "examples/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && copyfiles -u 2 \"src/nodes/**/*.html\" \"src/nodes/**/icons/*.svg\" dist/nodes/",
    "build:watch": "tsc --watch",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "node-red": {
    "version": ">=4.0.0",
    "nodes": {
      "surepetcare-config": "dist/nodes/surepetcare-config/surepetcare-config.js",
      "surepetcare-pets": "dist/nodes/surepetcare-pets/surepetcare-pets.js",
      "surepetcare-control": "dist/nodes/surepetcare-control/surepetcare-control.js"
    }
  },
  "peerDependencies": {
    "node-red": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "node-red": {
      "optional": true
    }
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/node-red-node-test-helper": "^0.3.5",
    "axios-mock-adapter": "^1.22.0",
    "copyfiles": "^2.4.1",
    "jest": "^30.4.2",
    "node-red": "^4.1.8",
    "node-red-node-test-helper": "^0.3.6",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src/__tests__"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80
      }
    }
  }
}
