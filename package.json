{
  "name": "node-red-contrib-surepetcare",
  "version": "0.1.0",
  "description": "Node-RED nodes for SurePetcare/SureFlap Connect smart cat flaps",
  "keywords": [
    "node-red",
    "sureflap",
    "surepetcare",
    "cat-flap",
    "pet"
  ],
  "author": "Dirk-Jan Faber",
  "license": "MIT",
  "scripts": {
    "build": "tsc && copyfiles -u 2 \"src/nodes/**/*.html\" \"src/nodes/**/icons/*.svg\" dist/nodes/",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "node-red": {
    "version": ">=2.0.0",
    "nodes": {
      "surepetcare-config": "dist/nodes/sureflap-config/sureflap-config.js",
      "surepetcare-pets": "dist/nodes/sureflap-pets/sureflap-pets.js",
      "surepetcare-control": "dist/nodes/sureflap-control/sureflap-control.js"
    }
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/node-red-node-test-helper": "^0.3.5",
    "axios-mock-adapter": "^1.22.0",
    "copyfiles": "^2.4.1",
    "jest": "^29.5.0",
    "node-red": "^4.1.8",
    "node-red-node-test-helper": "^0.3.6",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src/__tests__"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80
      }
    }
  }
}
